{
    "name": "nuxt-app",
    "type": "module",
    "private": true,
    "description": "My personal website",
    "homepage": "https://musterlabs.dev",
    "engines": {
        "node": ">=20",
        "pnpm": ">=8"
    },
    "scripts": {
        "add-component": "pnpm dlx shadcn-vue@latest add",
        "build": "nuxi build",
        "clean": "nuxi cleanup",
        "dev": "nuxi dev",
        "nuxi": "pnpm dlx nuxi add",
        "postinstall": "nuxi prepare && simple-git-hooks",
        "start": "node .output/server/index.mjs"
    },
    "dependencies": {
        "@radix-icons/vue": "1.0.0",
        "class-variance-authority": "0.7.0",
        "clsx": "2.1.0",
        "nuxt": "3.11.1",
        "radix-vue": "1.5.3",
        "tailwind-merge": "2.2.2",
        "tailwindcss-animate": "1.0.7",
        "vue": "3.4.21",
        "vue-router": "4.3.0"
    },
    "devDependencies": {
        "@antfu/eslint-config": "2.12.2",
        "@eslint/eslintrc": "3.0.2",
        "@nuxt/kit": "3.11.1",
        "@nuxtjs/google-fonts": "3.2.0",
        "@nuxtjs/tailwindcss": "6.11.4",
        "eslint": "8.57.0",
        "eslint-plugin-tailwindcss": "3.15.1",
        "eslint-plugin-unused-imports": "3.1.0",
        "lint-staged": "15.2.2",
        "nuxt-icon": "0.6.10",
        "shadcn-nuxt": "0.10.2",
        "simple-git-hooks": "2.11.1",
        "typescript": "5.4.4"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged"
    },
    "lint-staged": {
        "*": "eslint"
    }
}
